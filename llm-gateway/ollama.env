# ─────────────────────────────────────────────────────────────────────────────
# Ollama server tuning — memory & keep-alive settings
#
# This is the single place to change Ollama's runtime behaviour. Edit a value,
# then re-apply it with:
#
#     ./apply-ollama-env.sh
#
# Format: KEY=VALUE, one per line. Lines starting with # are ignored.
# Verify what's loaded and the unload timer any time with:  ollama ps
# ─────────────────────────────────────────────────────────────────────────────

# How long a model stays resident in RAM after its last request.
# This is what was keeping the model "running" after the response. Shorter =
# frees memory sooner; longer = faster follow-up requests (no reload).
#   "0"  = unload immediately   |   "30s" / "1m" / "5m" = keep this long
OLLAMA_KEEP_ALIVE=1m

# Default context window (in tokens) when a request doesn't specify one.
# This is the single biggest lever on RAM: the KV cache grows linearly with it.
# qwen2.5-coder defaults to 32768; 16384 halves the KV-cache memory while still
# giving plenty of room for coding tasks. Drop to 8192 if RAM is still tight.
OLLAMA_CONTEXT_LENGTH=16384

# Flash attention makes the KV cache far more memory-efficient. Required for
# OLLAMA_KV_CACHE_TYPE below to take effect.  1 = on, 0 = off.
OLLAMA_FLASH_ATTENTION=1

# Quantise the KV cache to shrink it further (needs flash attention on).
#   f16  = full precision (default, largest)
#   q8_0 = ~half the memory, negligible quality loss   ← recommended
#   q4_0 = ~quarter the memory, small quality loss
OLLAMA_KV_CACHE_TYPE=q8_0

# Keep at most one model resident at a time, so a second model can't stack on
# top of the first and blow past 24GB.
OLLAMA_MAX_LOADED_MODELS=1
